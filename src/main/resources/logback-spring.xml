<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <!-- timestamp -->
                <provider class="net.logstash.logback.composite.loggingevent.LoggingEventFormattedTimestampJsonProvider">
                    <fieldName>timestamp</fieldName>
                    <timestampFormat>yyyy-MM-dd'T'HH:mm:ss.SSS</timestampFormat>
                    <timeZone>Asia/Seoul</timeZone>
                </provider>
                <!-- level -->
                <provider class="net.logstash.logback.composite.loggingevent.LogLevelJsonProvider">
                    <fieldName>level</fieldName>
                </provider>
                <!-- service (정적 필드) -->
                <provider class="net.logstash.logback.composite.GlobalCustomFieldsJsonProvider">
                    <customFields>{"service":"interview-service"}</customFields>
                </provider>
                <!-- correlationId (MDC) -->
                <provider class="net.logstash.logback.composite.loggingevent.MdcJsonProvider">
                    <includeMdcKeyName>correlationId</includeMdcKeyName>
                </provider>
                <!-- message -->
                <provider class="net.logstash.logback.composite.loggingevent.MessageJsonProvider">
                    <fieldName>message</fieldName>
                </provider>
                <!-- logger_name → module -->
                <provider class="net.logstash.logback.composite.loggingevent.LoggerNameJsonProvider">
                    <fieldName>module</fieldName>
                </provider>
                <!-- error 중첩 객체 (예외 발생 시만) -->
                <provider class="io.wisoft.prepair.prepair_api.logging.ErrorJsonProvider"/>
            </providers>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>